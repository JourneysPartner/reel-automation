# reel-bot 用環境変数（実値は親フォルダの ig-tax-guardian/.env に置く想定）
# GitHub Actions では Secrets から注入する。
# ※ 変数名は大文字小文字も含めて .env の表記に合わせること。

# 台本生成（Anthropic Sonnet 4.6）
ANTHROPIC_API_KEY=

# 動画生成（Creatomate）※ .env では Creatomate_API_KEY / Creatomate_Template_ID 表記でも可
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_ID=

# 一時配信（Google Cloud Storage）
GCP_PROJECT_ID=                  # 例: reels-automation
GCS_BUCKET_NAME=                 # 例: tax-reels-public-assets
# ローカル: サービスアカウント鍵ファイルへのパス（.json）
GOOGLE_APPLICATION_CREDENTIALS=
# GitHub Actions: サービスアカウント JSON 全体を文字列で（GOOGLE_APPLICATION_CREDENTIALS の代わり）
GCP_SA_KEY=

# 保管（Google Drive / 個人Gmail は OAuth を使用）
GOOGLE_OAUTH_CLIENT_ID=          # GCP の OAuth クライアント（デスクトップアプリ）
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=      # `node scripts/google-oauth.js` で取得
GDRIVE_ARCHIVE_FOLDER_NAME=リール動画 (自動保管)   # 省略可（アプリ作成フォルダ名）

# 投稿（Instagram Graph API）
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# 状態管理（Google スプレッドシート / SA を編集者で共有しておく）
GSHEET_ID=                 # スプレッドシートのID（URLの /d/〜/edit の間）
GSHEET_TAB=posts           # タブ名（省略可）
LEAD_DAYS=3                # 公開日の何日前に生成するか

# 通知（ChatWork）
CHATWORK_API_TOKEN=        # ChatWork 設定 → API トークン
CHATWORK_ROOM_ID=          # 通知先ルームID（数字）

# 承認Webアプリ（Phase 2 / Apps Script）
APPROVAL_BASE_URL=         # Apps Script ウェブアプリの /exec URL
APPROVAL_SECRET=           # HMAC 共有秘密鍵（Apps Script の Script Properties と同値）

# VOICEVOX（ローカル or GHA service container）
VOICEVOX_HOST=http://localhost:50021
